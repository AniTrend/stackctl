{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "addLabels": [":dagger: dependencies"],
  "branchPrefix": "dependencies/",
  "reviewers": ["wax911"],
  "baseBranches": ["main"],
  "automerge": false,
  "automergeType": "pr",
  "automergeStrategy": "rebase",
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
